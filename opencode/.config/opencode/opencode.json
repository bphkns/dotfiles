{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    },
    "tanstack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@tanstack/cli@0.59.0",
        "mcp"
      ]
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {}
    },
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "slack-mcp-server@latest",
        "--transport",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "SLACK_MCP_XOXB_TOKEN": "{env:SLACK_MCP_XOXB_TOKEN}",
        "SLACK_MCP_XOXP_TOKEN": "{env:SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_XOXC_TOKEN": "{env:SLACK_MCP_XOXC_TOKEN}",
        "SLACK_MCP_XOXD_TOKEN": "{env:SLACK_MCP_XOXD_TOKEN}",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "true",
        "SLACK_MCP_MARK_TOOL": "true"
      }
    },
    "excalidraw": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--add-host=host.docker.internal:host-gateway",
        "-e",
        "EXPRESS_SERVER_URL=http://host.docker.internal:6100",
        "-e",
        "ENABLE_CANVAS_SYNC=true",
        "ghcr.io/yctimlin/mcp_excalidraw:latest"
      ],
      "enabled": true
    }
  },
  "provider": {
    "github-copilot": {
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex",
          "capabilities": {
            "reasoning": true
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        }
      }
    },
    "cursor-acp": {
      "name": "Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1"
      },
      "models": {
        "auto": {
          "name": "Auto"
        },
        "composer-1.5": {
          "name": "Composer 1.5"
        },
        "composer-1": {
          "name": "Composer 1"
        },
        "gpt-5.3-codex-low": {
          "name": "GPT-5.3 Codex Low"
        },
        "gpt-5.3-codex-low-fast": {
          "name": "GPT-5.3 Codex Low Fast"
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex"
        },
        "gpt-5.3-codex-fast": {
          "name": "GPT-5.3 Codex Fast"
        },
        "gpt-5.3-codex-high": {
          "name": "GPT-5.3 Codex High"
        },
        "gpt-5.3-codex-high-fast": {
          "name": "GPT-5.3 Codex High Fast"
        },
        "gpt-5.3-codex-xhigh": {
          "name": "GPT-5.3 Codex Extra High"
        },
        "gpt-5.3-codex-xhigh-fast": {
          "name": "GPT-5.3 Codex Extra High Fast"
        },
        "gpt-5.2": {
          "name": "GPT-5.2"
        },
        "gpt-5.3-codex-spark-preview": {
          "name": "GPT-5.3 Codex Spark"
        },
        "gpt-5.2-codex-low": {
          "name": "GPT-5.2 Codex Low"
        },
        "gpt-5.2-codex-low-fast": {
          "name": "GPT-5.2 Codex Low Fast"
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex"
        },
        "gpt-5.2-codex-fast": {
          "name": "GPT-5.2 Codex Fast"
        },
        "gpt-5.2-codex-high": {
          "name": "GPT-5.2 Codex High"
        },
        "gpt-5.2-codex-high-fast": {
          "name": "GPT-5.2 Codex High Fast"
        },
        "gpt-5.2-codex-xhigh": {
          "name": "GPT-5.2 Codex Extra High"
        },
        "gpt-5.2-codex-xhigh-fast": {
          "name": "GPT-5.2 Codex Extra High Fast"
        },
        "gpt-5.1-codex-max": {
          "name": "GPT-5.1 Codex Max"
        },
        "gpt-5.1-codex-max-high": {
          "name": "GPT-5.1 Codex Max High"
        },
        "opus-4.6-thinking": {
          "name": "Claude 4.6 Opus (Thinking)"
        },
        "gpt-5.2-high": {
          "name": "GPT-5.2 High"
        },
        "sonnet-4.6": {
          "name": "Claude 4.6 Sonnet"
        },
        "sonnet-4.6-thinking": {
          "name": "Claude 4.6 Sonnet (Thinking)"
        },
        "opus-4.6": {
          "name": "Claude 4.6 Opus"
        },
        "opus-4.5": {
          "name": "Claude 4.5 Opus"
        },
        "opus-4.5-thinking": {
          "name": "Claude 4.5 Opus (Thinking)"
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro"
        },
        "grok": {
          "name": "Grok"
        },
        "sonnet-4.5": {
          "name": "Claude 4.5 Sonnet"
        },
        "sonnet-4.5-thinking": {
          "name": "Claude 4.5 Sonnet (Thinking)"
        },
        "gpt-5.1-high": {
          "name": "GPT-5.1 High"
        },
        "gemini-3-pro": {
          "name": "Gemini 3 Pro"
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash"
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini"
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5"
        }
      }
    }
  },
  "autoshare": false,
  "autoupdate": true,
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@nick-vi/opencode-type-inject@1.5.1",
    "opencode-pty@0.2.0",
    "opencode-anthropic-auth@0.0.13",
    "cursor-acp"
  ],
  "instructions": [
    "/home/bikash/.config/opencode/instructions/global.md",
    "/home/bikash/.config/opencode/plugin/shell-strategy/shell_strategy.md"
  ],
  "agent": {
    "socratic-tutor": {
      "description": "Socratic teaching mode - guides learning through questions",
      "mode": "primary",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "todo": true,
        "task": true
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "webfetch": "allow",
        "question": "allow"
      }
    }
  }
}
