{
  "$schema": "https://opencode.ai/config.json",
  "theme": "everforest",
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    },
    "tanstack": {
      "type": "local",
      "command": ["npx", "-y", "@tanstack/cli@0.59.0", "mcp"]
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {}
    },
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "hubspot": {
      "type": "remote",
      "url": "https://mcp.hubspot.com/",
      "oauth": {
        "clientId": "{env:HUBSPOT_MCP_CLIENT_ID}",
        "clientSecret": "{env:HUBSPOT_MCP_CLIENT_SECRET}"
      }
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "slack-mcp-server@latest",
        "--transport",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "SLACK_MCP_XOXB_TOKEN": "{env:SLACK_MCP_XOXB_TOKEN}",
        "SLACK_MCP_XOXP_TOKEN": "{env:SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_XOXC_TOKEN": "{env:SLACK_MCP_XOXC_TOKEN}",
        "SLACK_MCP_XOXD_TOKEN": "{env:SLACK_MCP_XOXD_TOKEN}",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "true",
        "SLACK_MCP_MARK_TOOL": "true"
      }
    },
    "excalidraw": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--add-host=host.docker.internal:host-gateway",
        "-e",
        "EXPRESS_SERVER_URL=http://host.docker.internal:6100",
        "-e",
        "ENABLE_CANVAS_SYNC=true",
        "ghcr.io/yctimlin/mcp_excalidraw:latest"
      ],
      "enabled": true
    },
    "posthog": {
      "type": "remote",
      "url": "https://mcp.posthog.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:POSTHOG_API_KEY}"
      }
    },
    "trigify": {
      "type": "remote",
      "url": "https://api.trigify.io/mcp",
      "enabled": true,
      "oauth": {}
    },
    "linkedin": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-v",
        "/home/bikash/.linkedin-mcp:/home/pwuser/.linkedin-mcp",
        "stickerdaniel/linkedin-mcp-server:4.1.2"
      ],
      "enabled": true
    }
  },
  "provider": {},
  "autoshare": false,
  "autoupdate": true,
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@nick-vi/opencode-type-inject@1.5.1",
    "opencode-pty@0.2.0",
    "opencode-anthropic-auth@0.0.13"
  ],
  "instructions": [
    "/home/bikash/.config/opencode/instructions/global.md",
    "/home/bikash/.config/opencode/plugin/shell-strategy/shell_strategy.md"
  ],
  "agent": {
    "socratic-tutor": {
      "description": "Socratic teaching mode - guides learning through questions",
      "mode": "primary",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "todo": true,
        "task": true
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "webfetch": "allow",
        "question": "allow"
      }
    }
  }
}
